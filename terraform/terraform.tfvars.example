# Copy this file to terraform.tfvars and fill in all values.
#
# IMPORTANT: terraform.tfvars contains sensitive values (bootstrap_admin_pass,
# oidc_client_secret). Add it to .gitignore — do NOT commit it.

# ── Required ──────────────────────────────────────────────────────────────────

project_id = "pubsec-se"
region     = "us-central1"

# Build and push the image before applying. The docker_push_command output
# shows the exact command to use after the first apply.
container_image = "us-central1-docker.pkg.dev/pubsec-se/cloud-run-source-deploy/fileshare:latest"

# Set to false if the file-storage bucket already exists (e.g. pubsec-fileshare
# in the pubsec-se project). Set to true to have Terraform create it.
create_file_bucket = false
file_bucket_name   = "pubsec-fileshare"

# The SQLite FUSE volume bucket — always created by Terraform.
db_bucket_name = "pubsec-fileshare-db"

# Initial admin credentials for the bootstrap job.
# SENSITIVE — do not commit.
bootstrap_admin_user = "admin"
bootstrap_admin_pass = "CHANGE_ME_BEFORE_APPLY"

# ── Optional: OIDC login ──────────────────────────────────────────────────────
# Leave all three empty to disable OIDC. All three must be non-empty to enable.
# Create an OAuth 2.0 Client ID in GCP Console first:
#   APIs & Services → Credentials → OAuth 2.0 Client ID
#   Authorized redirect URI: {service_url}/api/auth/callback/oidc
#   (the exact URI is printed as the oidc_callback_url output after apply)

oidc_issuer        = ""   # e.g. "https://accounts.google.com"
oidc_client_id     = ""   # SENSITIVE — do not commit
oidc_client_secret = ""   # SENSITIVE — do not commit

# Optional: auto-grant upload+admin to users whose email matches this domain
# on their first OIDC sign-in. Leave empty to require manual permission grants.
# oidc_admin_domain = ""  # e.g. "example.com"

# ── Optional: agent device-grant + key minting ────────────────────────────────
# Lets an autonomous agent obtain a short-lived, upload-scoped key via the OAuth
# Device Authorization Grant. Register a SECOND Google OAuth client of type
# "TVs and Limited Input devices" (APIs & Services → Credentials → Create
# credentials → OAuth client ID → Application type: TVs and Limited Input
# devices) and populate the two values below. Both must be set together to
# enable the agent device-grant endpoints. See AGENTS.md for the full step.

# agent_oidc_client_id     = ""   # SENSITIVE — do not commit
# agent_oidc_client_secret = ""   # SENSITIVE — do not commit

# Lifetime (seconds) of a minted agent upload key. Defaults to 900 (15 minutes).
# agent_key_ttl_seconds = 900

# Optional dedicated signing secret for agent keys. Leave empty to reuse
# AUTH_SECRET (the app default).
# agent_key_secret = ""   # SENSITIVE — do not commit

# ── Custom domain (optional) ──────────────────────────────────────────────────
# When set, this hostname is added to the GCS bucket CORS policy so that
# browser XHR uploads from the custom domain are allowed.
# Also used by the Cloud Run domain mapping in dns.tf.

# custom_domain = "fileshare.cgr-pubsec.dev"

# ── Optional overrides ────────────────────────────────────────────────────────

# cloud_run_service_name = "fileshare"
# cloud_run_job_name     = "fileshare-bootstrap"
# cloud_run_memory       = "512Mi"
# cloud_run_cpu          = "1"
# artifact_registry_repo = "cloud-run-source-deploy"
