# Copy this file to terraform.tfvars and fill in all values.
#
# IMPORTANT: terraform.tfvars contains sensitive values (bootstrap_admin_pass,
# oidc_client_secret). Add it to .gitignore — do NOT commit it.

# ── Required ──────────────────────────────────────────────────────────────────

project_id = "pubsec-se"
region     = "us-central1"

# Build and push the image before applying. The docker_push_command output
# shows the exact command to use after the first apply.
container_image = "us-central1-docker.pkg.dev/pubsec-se/cloud-run-source-deploy/fileshare:latest"

# Set to false if the file-storage bucket already exists (e.g. pubsec-fileshare
# in the pubsec-se project). Set to true to have Terraform create it.
create_file_bucket = false
file_bucket_name   = "pubsec-fileshare"

# The SQLite FUSE volume bucket — always created by Terraform.
db_bucket_name = "pubsec-fileshare-db"

# Initial admin credentials for the bootstrap job.
# SENSITIVE — do not commit.
bootstrap_admin_user = "admin"
bootstrap_admin_pass = "CHANGE_ME_BEFORE_APPLY"

# ── OIDC issuer + admin domain (non-secret) ───────────────────────────────────
# These two are consumed by BOTH interactive OIDC login AND the agent
# device-grant flow (which reuses the issuer for endpoint discovery and the
# admin domain for permission resolution). Set them here whenever you enable
# EITHER feature. They are non-secret, so terraform.tfvars is their home.
#
#   - oidc_issuer is REQUIRED for the agent flow; without it device-grant fails
#     with "AUTH_OIDC_ISSUER is not configured".
#   - oidc_admin_domain controls which accounts get upload+admin on the minted
#     key (and on first interactive OIDC sign-in). Leave empty to require manual
#     permission grants.

oidc_issuer       = ""   # e.g. "https://accounts.google.com"
oidc_admin_domain = ""   # e.g. "example.com"

# ── Optional: interactive OIDC (SSO) login ────────────────────────────────────
# Enables the "Sign in with SSO" button. Requires oidc_issuer (above) PLUS these
# two from a "Web application" OAuth client whose authorized redirect URI is
# {service_url}/api/auth/callback/oidc (printed as the oidc_callback_url output).
# NOT needed for the agent device-grant flow.

oidc_client_id     = ""   # SENSITIVE — do not commit
oidc_client_secret = ""   # SENSITIVE — do not commit

# ── Agent device-grant secrets live in .env, NOT here ─────────────────────────
# The agent client id/secret are sourced from the repo-root .env by the deploy
# scripts (deploy.sh / apply.sh, via common.sh -> load_env_tfvars) and passed to
# Terraform as TF_VAR_*. Do NOT add agent_oidc_client_id / agent_oidc_client_secret
# / agent_key_secret here: TF_VAR_* is the lowest-precedence source, so an entry
# in this file (even an empty "") would OVERRIDE the value from .env and silently
# break the feature. Set these in .env instead:
#
#   AGENT_OIDC_CLIENT_ID=...        # from the "TVs and Limited Input devices" client
#   AGENT_OIDC_CLIENT_SECRET=...
#   AGENT_KEY_TTL_SECONDS=900       # optional; minted-key lifetime, default 900
#   AGENT_KEY_SECRET=...            # optional; falls back to AUTH_SECRET when unset
#
# See AGENTS.md for the full setup, including registering the second OAuth client.

# ── Custom domain (optional) ──────────────────────────────────────────────────
# When set, this hostname is added to the GCS bucket CORS policy so that
# browser XHR uploads from the custom domain are allowed.
# Also used by the Cloud Run domain mapping in dns.tf.

# custom_domain = "fileshare.cgr-pubsec.dev"

# ── Optional overrides ────────────────────────────────────────────────────────

# cloud_run_service_name = "fileshare"
# cloud_run_job_name     = "fileshare-bootstrap"
# cloud_run_memory       = "512Mi"
# cloud_run_cpu          = "1"
# artifact_registry_repo = "cloud-run-source-deploy"
